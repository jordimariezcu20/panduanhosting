---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Hubungi Kami | PanduanHosting.id"
  description="Hubungi tim PanduanHosting.id untuk pertanyaan, masukan, atau kerjasama."
  canonical="/hubungi-kami"
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Hubungi Kami</h1>
    <p class="text-gray-700 mb-8">
      Ada pertanyaan, koreksi, atau ingin bekerjasama? Kirim pesan kepada kami.
    </p>
    <form class="space-y-4" name="contact" netlify>
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nama</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#1565C0] focus:ring-1 focus:ring-[#1565C0]"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#1565C0] focus:ring-1 focus:ring-[#1565C0]"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Pesan</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:border-[#1565C0] focus:ring-1 focus:ring-[#1565C0]"
        ></textarea>
      </div>
      <button
        type="submit"
        class="bg-[#1565C0] hover:bg-[#0D47A1] text-white font-semibold px-6 py-3 rounded-lg transition-colors"
      >
        Kirim Pesan
      </button>
    </form>
  </div>
</BaseLayout>
