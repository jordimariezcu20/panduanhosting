---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = (await getCollection('review')).sort(
  (a, b) =>
    new Date(b.data.lastUpdated ?? b.data.publishDate ?? '').getTime() -
    new Date(a.data.lastUpdated ?? a.data.publishDate ?? '').getTime()
);
---
<BaseLayout
  title="Review Hosting | PanduanHosting.id"
  description="Review jujur dan mendalam tentang layanan hosting web terpopuler di Indonesia."
  canonical="/review"
>
  <main class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-800 mb-2">Review Hosting</h1>
    <p class="text-gray-500 mb-8">Ulasan jujur berdasarkan pengujian langsung layanan hosting Indonesia.</p>

    {entries.length === 0 ? (
      <p class="text-gray-400 text-center py-16">Belum ada artikel. Segera hadir!</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-6">
        {entries.map((entry) => (
          <a href={`/review/${entry.slug}`} class="block border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
            <span class="text-xs font-semibold text-[#1565C0] uppercase tracking-wide">{entry.data.category}</span>
            <h2 class="text-lg font-bold text-gray-800 mt-1 mb-2">{entry.data.title}</h2>
            <p class="text-gray-500 text-sm line-clamp-2">{entry.data.description}</p>
            {entry.data.publishDate && (
              <p class="text-xs text-gray-400 mt-3">{new Date(entry.data.publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </main>
</BaseLayout>
