---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  publishDate?: string;
  lastUpdated?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og-default.png',
  ogType = 'website',
  noindex = false,
  publishDate,
  lastUpdated,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://panduanhosting.id';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }
    <meta name="theme-color" content="#1565C0" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="PanduanHosting.id" />
    {ogType === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}
    {ogType === 'article' && lastUpdated && <meta property="article:modified_time" content={lastUpdated} />}
    {ogType === 'article' && <meta property="article:author" content="Tim PanduanHosting" />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@panduanhosting" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload woff2 font file directly to eliminate 2-hop waterfall -->
    <link rel="preload" as="font" type="font/woff2" crossorigin
      href="https://fonts.gstatic.com/s/plusjakartasans/v12/LDIoaomQNQcsA88c7O9yZ4KMCoOg4Ko20yw.woff2" />
    <!-- Load Google Fonts CSS async (non-render-blocking) -->
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <script defer src="https://umami-production-c3fa.up.railway.app/script.js" data-website-id="84a44d60-f5d9-4bbc-8b32-082775931796"></script>
  </head>
  <body class="font-sans text-gray-800 bg-white">
    <header class="border-b border-gray-200 sticky top-0 z-40 bg-white/95 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="font-bold text-[#1565C0] text-lg">
          PanduanHosting<span class="text-gray-500">.id</span>
        </a>
        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a href="/panduan" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="panduan">Panduan</a>
          <a href="/tutorial" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="tutorial">Tutorial</a>
          <a href="/rekomendasi" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="rekomendasi">Rekomendasi</a>
          <a href="/review" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="review">Review</a>
          <a href="/perbandingan" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="perbandingan">Perbandingan</a>
          <a href="/promo" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-click" data-umami-event-section="promo">Promo</a>
        </nav>
        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
          aria-label="Buka menu navigasi"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-6 h-0.5 bg-gray-700 transition-all" id="ham-1"></span>
          <span class="block w-6 h-0.5 bg-gray-700 transition-all" id="ham-2"></span>
          <span class="block w-6 h-0.5 bg-gray-700 transition-all" id="ham-3"></span>
        </button>
      </div>
      <!-- Mobile nav drawer -->
      <nav
        id="mobile-menu"
        class="hidden md:hidden border-t border-gray-100 bg-white px-4 py-3 flex flex-col gap-1 text-sm"
        aria-label="Navigasi mobile"
      >
        <a href="/panduan" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="panduan">Panduan</a>
        <a href="/tutorial" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="tutorial">Tutorial</a>
        <a href="/rekomendasi" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="rekomendasi">Rekomendasi</a>
        <a href="/review" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="review">Review</a>
        <a href="/perbandingan" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="perbandingan">Perbandingan</a>
        <a href="/promo" class="py-2 hover:text-[#1565C0]" data-umami-event="nav-mobile-click" data-umami-event-section="promo">Promo</a>
      </nav>
    </header>
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          const isOpen = menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!isOpen));
        });
      }
    </script>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16 py-8 text-sm text-gray-500">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-6 mb-6">
          <div>
            <p class="font-semibold text-gray-700 mb-2">PanduanHosting.id</p>
            <p>Panduan hosting web terpercaya untuk pengguna Indonesia.</p>
          </div>
          <div>
            <p class="font-semibold text-gray-700 mb-2">Tautan</p>
            <ul class="space-y-1">
              <li><a href="/tentang-kami" class="hover:text-[#1565C0]">Tentang Kami</a></li>
              <li><a href="/kebijakan-privasi" class="hover:text-[#1565C0]">Kebijakan Privasi</a></li>
              <li><a href="/pengungkapan-afiliasi" class="hover:text-[#1565C0]">Pengungkapan Afiliasi</a></li>
              <li><a href="/hubungi-kami" class="hover:text-[#1565C0]">Hubungi Kami</a></li>
            </ul>
          </div>
          <div>
            <p class="font-semibold text-gray-700 mb-2">Kategori</p>
            <ul class="space-y-1">
              <li><a href="/panduan" class="hover:text-[#1565C0]">Panduan</a></li>
              <li><a href="/tutorial" class="hover:text-[#1565C0]">Tutorial</a></li>
              <li><a href="/rekomendasi" class="hover:text-[#1565C0]">Rekomendasi</a></li>
              <li><a href="/review" class="hover:text-[#1565C0]">Review</a></li>
              <li><a href="/perbandingan" class="hover:text-[#1565C0]">Perbandingan</a></li>
              <li><a href="/promo" class="hover:text-[#1565C0]">Promo</a></li>
            </ul>
          </div>
        </div>
        <p class="text-center text-xs border-t border-gray-100 pt-4">
          © {new Date().getFullYear()} PanduanHosting.id · Situs ini mengandung tautan afiliasi.
        </p>
      </div>
    </footer>

    <script>
      // Global click delegation — tracks /go/ affiliate links not already tagged with data-umami-event
      // and outbound external links
      document.addEventListener('click', function (e) {
        const a = e.target instanceof Element ? e.target.closest('a[href]') : null;
        if (!a) return;

        const href = a.getAttribute('href') ?? '';

        // Affiliate /go/ links in prose/markdown (static CTAs already have data-umami-event)
        if (href.startsWith('/go/') && !a.hasAttribute('data-umami-event')) {
          const provider = href.slice(4);
          const position =
            (a.closest('[data-track-position]') as HTMLElement | null)?.dataset.trackPosition ??
            'article-body';
          window.umami?.track('affiliate-click', { provider, position });
          return;
        }

        // Outbound external links (not /go/, not same origin)
        if (href.startsWith('http') && !href.includes('panduanhosting.id') && !a.hasAttribute('data-umami-event')) {
          const domain = (() => { try { return new URL(href).hostname; } catch { return href; } })();
          window.umami?.track('outbound-click', { url: href, domain });
        }
      });
    </script>
  </body>
</html>
