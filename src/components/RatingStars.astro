---
interface Props {
  rating: number;
}
const { rating } = Astro.props;
const fullStars = Math.floor(rating / 2);
const hasHalf = (rating / 2) % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---
<span class="inline-flex items-center gap-0.5" aria-label={`Rating: ${rating} dari 10`}>
  {Array.from({ length: fullStars }).map(() => <span class="text-yellow-400">★</span>)}
  {hasHalf && <span class="text-yellow-400">½</span>}
  {Array.from({ length: emptyStars }).map(() => <span class="text-gray-300">★</span>)}
  <span class="ml-1 text-sm text-gray-600">({rating}/10)</span>
</span>
