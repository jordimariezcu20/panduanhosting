---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
{toc.length > 0 && (
  <nav class="toc bg-gray-50 border border-gray-200 rounded-lg p-4 my-6" aria-label="Daftar Isi">
    <details open class="md:open">
      <summary class="font-semibold text-[#1565C0] cursor-pointer list-none flex items-center justify-between">
        Daftar Isi
        <span class="text-gray-400 text-sm md:hidden">▼</span>
      </summary>
      <ol class="mt-3 space-y-1 text-sm">
        {toc.map((h) => (
          <li class={h.depth === 3 ? 'ml-4' : ''}>
            <a href={`#${h.slug}`} class="text-gray-700 hover:text-[#1565C0] hover:underline">
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  </nav>
)}
