---
interface Props {
  name: string;
  rating: number;
  pros: string[];
  cons: string[];
  price: string;
  url: string;
  silo?: string;
}
const { name, rating, pros, cons, price, url, silo = 'review' } = Astro.props;
const stars = Math.round(rating / 2);
---
<div class="border border-gray-200 rounded-xl p-6 my-6 shadow-sm">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xl font-bold text-[#1565C0]">{name}</h3>
    <div class="flex items-center gap-2">
      <span class="text-2xl font-bold text-[#2E7D32]">{rating}/10</span>
    </div>
  </div>
  <p class="text-gray-600 mb-4">Harga mulai: <strong>{price}</strong></p>
  <div class="grid md:grid-cols-2 gap-4 mb-4">
    <div>
      <h4 class="font-semibold text-green-700 mb-2">✓ Kelebihan</h4>
      <ul class="space-y-1">
        {pros.map((p) => <li class="text-sm text-gray-700">• {p}</li>)}
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-red-700 mb-2">✗ Kekurangan</h4>
      <ul class="space-y-1">
        {cons.map((c) => <li class="text-sm text-gray-700">• {c}</li>)}
      </ul>
    </div>
  </div>
  <a
    href={`${url}?utm_source=panduanhosting.id&utm_medium=affiliate&utm_campaign=${silo}`}
    rel="nofollow noopener sponsored"
    target="_blank"
    class="inline-block bg-[#2E7D32] hover:bg-[#1B5E20] text-white font-semibold px-6 py-3 rounded-lg transition-colors w-full text-center"
  >
    Coba {name} Sekarang
  </a>
</div>
