---
interface Props {
  title: string;
  description: string;
  url: string;
  cta: string;
  expiry?: string;
  provider: string;
  silo?: string;
}
const { title, description, url, cta, expiry, provider, silo = 'promo' } = Astro.props;
---
<div class="border-2 border-[#2E7D32] rounded-xl p-6 my-6 bg-green-50">
  <p class="text-xs font-semibold text-[#2E7D32] uppercase tracking-wide mb-1">Penawaran Spesial</p>
  <h3 class="text-lg font-bold text-gray-800 mb-2">{title}</h3>
  <p class="text-gray-700 text-sm mb-4">{description}</p>
  {expiry && <p class="text-xs text-red-600 mb-3">⏰ Berlaku hingga: {expiry}</p>}
  <a
    href={`${url}?utm_source=panduanhosting.id&utm_medium=affiliate&utm_campaign=${silo}`}
    rel="nofollow noopener sponsored"
    target="_blank"
    class="inline-block bg-[#2E7D32] hover:bg-[#1B5E20] text-white font-semibold px-6 py-3 rounded-lg transition-colors"
  >
    {cta}
  </a>
</div>
