---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
const siteUrl = 'https://panduanhosting.id';

const schemaItems = crumbs.map((c, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: c.label,
  ...(c.href ? { item: `${siteUrl}${c.href}` } : {}),
}));
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: schemaItems };
---
<nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-4">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((c, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">›</span>}
        {c.href
          ? <a href={c.href} class="hover:text-[#1565C0] hover:underline">{c.label}</a>
          : <span class="text-gray-700 font-medium">{c.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
