---
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  schema: string;
  title: string;
  description: string;
  url: string;
  publishDate: string;
  lastUpdated: string;
  author: string;
  image?: string;
  rating?: number;
  reviewTarget?: string; // name of the product/service being reviewed
  faqItems?: FaqItem[];
}
const { schema, title, description, url, publishDate, lastUpdated, author, image, rating, reviewTarget, faqItems = [] } = Astro.props;
const siteUrl = 'https://panduanhosting.id';
const logoUrl = `${siteUrl}/favicon.svg`;

const baseSchema = {
  '@context': 'https://schema.org',
  headline: title,
  description,
  url,
  inLanguage: 'id',
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  datePublished: publishDate,
  dateModified: lastUpdated,
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'PanduanHosting.id',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
  ...(image ? { image: { '@type': 'ImageObject', url: `${siteUrl}${image}` } } : {}),
};

const schemaMap: Record<string, object> = {
  Article: { '@type': 'Article', ...baseSchema },
  ItemList: { '@type': 'ItemList', ...baseSchema },
  HowTo: { '@type': 'HowTo', ...baseSchema },
  Review: {
    '@type': 'Review',
    ...baseSchema,
    itemReviewed: {
      '@type': 'SoftwareApplication',
      name: reviewTarget ?? title.replace(/^Review\s+/i, ''),
      applicationCategory: 'WebApplication',
    },
    ...(rating ? {
      reviewRating: {
        '@type': 'Rating',
        ratingValue: rating,
        bestRating: 5,
        worstRating: 1,
      }
    } : {}),
  },
  FAQPage: {
    '@type': 'FAQPage',
    ...baseSchema,
    ...(faqItems.length > 0 ? {
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    } : {}),
  },
};

const jsonLd = schemaMap[schema] ?? schemaMap['Article'];
---
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
